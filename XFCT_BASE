#!/data/data/com.termux/files/usr/bin/bash

# --- Color Palette ---
G_BLUE='\e[38;5;33m'
G_RED='\e[38;5;196m'
G_YELLOW='\e[38;5;226m'
G_GREEN='\e[38;5;40m'
G_PURPLE='\e[38;5;129m'
AQUA='\e[38;5;51m'
NC='\e[0m' 

# --- Progress Function ---
show_progress() {
  local pid=$1
  local message=$2
  echo -ne "${AQUA}$message [${NC}"
  while kill -0 $pid 2>/dev/null; do
    echo -ne "█"
    sleep 0.5
  done
  echo -e "${AQUA}] Done!${NC}"
}

# --- Main Menu Loop ---
while true; do
  clear
  echo -e "${G_BLUE} __  __ ${G_RED}___ ${G_YELLOW}___ ${G_GREEN}_____ ${NC}"
  echo -e "${G_BLUE} \ \/ / ${G_RED}| __|${G_YELLOW} __|${G_GREEN}_    _|${NC}"
  echo -e "${G_BLUE}  >  <  ${G_RED}| _| ${G_YELLOW}(__  ${G_GREEN}| |  ${NC}"
  echo -e "${G_BLUE} /_/\_\ ${G_RED}|_| ${G_YELLOW}\___| ${G_GREEN}|_|  ${NC}"
  echo -e "      ${G_BLUE}C${G_RED}h${G_YELLOW}r${G_BLUE}o${G_GREEN}m${G_RED}e${G_BLUE}b${G_RED}o${G_YELLOW}o${G_BLUE}k ${NC}Edition"
  echo -e "---------------------------------"
  
  echo -e "1) ${AQUA}Launch XFCE Desktop${NC}"
  echo -e "2) ${G_RED}System Update & Upgrade${NC}"
  echo -e "3) ${G_YELLOW}Install Ubuntu (Proot)${NC}"
  echo -e "4) ${AQUA}Setup Environment (X11/DBus/XFCE)${NC}"
  echo -e "5) ${G_PURPLE}Install Audio & Goodies${NC}"
  echo -e "6) ${G_GREEN}Exit${NC}"
  echo ""
  
  read -p "Select an option [1-5]: " choice

  case $choice in
    1)
      if ! command -v xfce4-session &> /dev/null; then
          echo -e "\n${G_RED}[!] ERROR: XFCE is not installed.${NC}"
          echo -e "Please run ${G_AQUA}Option 4${NC} first to install everything."
          read -p "Press Enter to return..."
      else
          echo -e "\nInitializing XFCT..."
          xfct
          break
      fi
      ;;
      
2)
      echo -e "\n${G_RED}--- SYSTEM REPAIR & UPDATE ---${NC}"
      echo -e "${G_YELLOW}[1/3] Syncing Repositories...${NC}"
      apt-get update -y
      
      echo -e "${G_YELLOW}[2/3] Fixing Broken Dependencies...${NC}"
      # This specifically fixes the libpcre2-8.so error
      apt --fix-broken install -y
      
      echo -e "${G_YELLOW}[3/3] Performing Deep Upgrade...${NC}"
      # 'dist-upgrade' is safer for XFCE than 'upgrade'
      apt-get dist-upgrade -y -o Dpkg::Options::="--force-confold"
      
      echo -e "\n${G_GREEN}SUCCESS: System libraries are synced and healthy.${NC}"
      read -p "Press [Enter] to return to the menu..."
      ;;

3) echo -e "\nStarting Ubuntu Installation..." 
pkg install proot-distro -y > /dev/null 2>&1 
proot-distro install ubuntu > /dev/null 2>&1 & 
show_progress $! "Downloading Ubuntu" 
read -p "Press Enter to return to menu..."
 ;;

4)
      echo -e "\n${G_AQUA}--- Starting System Construction  ---${NC}"
      
      # 1. Update the repository list first
      pkg update -y
      echo -e "${G_GREEN}[+] Repositories synced.${NC}"

      # 2. Install X11 Repo (Required for the display server)
      pkg install x11-repo -y
      echo -e "${G_GREEN}[+] X11 Repository added.${NC}"

      # 3. Install Display Server (One by one, no backgrounding)
      echo -e "${G_YELLOW}Installing Termux-X11...${NC}"
      pkg install termux-x11-nightly -y
      
      # 4. Install Communication Bus
      echo -e "${G_YELLOW}Installing DBus...${NC}"
      pkg install dbus -y
      
      # 5. Install the Desktop Environment (The big one)
      echo -e "${G_YELLOW}Installing XFCE4 Desktop (This takes a minute)...${NC}"
      pkg install xfce4 -y

      # 6. Create the launcher script
      echo -e "${G_AQUA}Generating Launcher...${NC}"
      cat << 'EOF' > $PREFIX/bin/xfct
#!/data/data/com.termux/files/usr/bin/bash
pkill -f termux-x11; pkill -f dbus-daemon
export DISPLAY=:1; export XDG_RUNTIME_DIR=${TMPDIR}
termux-x11 :1 -ac & 
sleep 2
am start --user 0 -n com.termux.x11/.MainActivity > /dev/null 2>&1
dbus-launch --exit-with-session xfce4-session
EOF
      chmod +x $PREFIX/bin/xfct
      
      echo -e "\n${G_GREEN}SUCCESS: Environment is fully built.${NC}"
      echo "Everything installed one by one without errors."
      read -p "Press Enter to return to menu..."
      ;;      

    5)
      # --- THE GATEKEEPER CHECK ---
      if ! command -v xfce4-session &> /dev/null; then
          echo -e "\n${G_RED}[!] ACCESS DENIED: Foundation Missing${NC}"
          echo -e "You must install the Environment (${AQUA}Option 4${NC}) first."
          read -p "Press [Enter] to return to the menu..."
          continue
      fi

      echo -e "\n${G_PURPLE}--- Installing Audio & XFCE Goodies ---${NC}"
      
      # 1. Ensure the pulse directory exists before configuration
      mkdir -p $PREFIX/etc/pulse
      echo -e "${G_GREEN}[+] PulseAudio directory initialized.${NC}"

      # 2. Install Audio Stack (One by one for stability)
      echo -e "${G_YELLOW}Installing PulseAudio...${NC}"
      pkg install pulseaudio -y
      
      echo -e "${G_YELLOW}Installing Volume Control (Pavucontrol)...${NC}"
      pkg install pavucontrol -y

      # 3. Install XFCE Plugins (The "Goodies")
      echo -e "${G_YELLOW}Installing Panel Plugins (Audio, Power, Whisker)...${NC}"
      pkg install xfce4-pulseaudio-plugin xfce4-power-manager xfce4-whiskermenu-plugin -y

      # 4. Apply the TCP Audio Fix (Allows Termux to talk to the X11 App)
      echo -e "${G_YELLOW}Configuring Audio Protocol...${NC}"
      echo "load-module module-native-protocol-tcp auth-ip-acl=127.0.0.1 auth-anonymous=1" >> $PREFIX/etc/pulse/default.pa

      # 5. Inject Audio Start into your 'xfct' launcher
      if ! grep -q "pulseaudio --start" "$PREFIX/bin/xfct"; then
          echo -e "${G_YELLOW}Updating Launcher with Audio Autostart...${NC}"
          sed -i '2i pulseaudio --start --exit-idle-time=-1' $PREFIX/bin/xfct
      fi
      
      echo -e "\n${G_GREEN}SUCCESS: Audio and Goodies are now integrated!${NC}"
      echo -e "Next time you launch (Option 1), sound will be active."
      read -p "Press [Enter] to return to menu..."
      ;;

    6)
      echo -e "\nExiting... See ya!"
      exit 0
      ;;
      
    *)
      echo -e "\n${G_RED}Invalid option, try again.${NC}"
      sleep 1
      ;;
  esac
done
